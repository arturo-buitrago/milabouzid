---
// One event card. All fields from the `events` collection. `more_info_url` optional
// (button disabled when blank); sold_out shows a badge.
import Button from './Button.astro';
import { isFilled } from '../lib/content';

interface Props {
  title: string;
  date: Date;
  venue: string;
  location?: string;
  moreInfoUrl?: string;
  soldOut?: boolean;
}
const { title, date, venue, location, moreInfoUrl, soldOut = false } = Astro.props;
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const dateISO = date.toISOString().slice(0, 10);
---

<article class="card">
  <div class="head">
    <h3>{title}</h3>
    {soldOut && <span class="badge">Sold out</span>}
  </div>
  <p class="meta">
    <time datetime={dateISO}>{dateFmt.format(date)}</time>
    <span class="venue">{venue}{isFilled(location) ? `, ${location}` : ''}</span>
  </p>
  <Button href={moreInfoUrl} variant="outline" disabled={!isFilled(moreInfoUrl)}>
    More info
  </Button>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.25rem;
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.35);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }
  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--yellow);
    font-size: clamp(1.1rem, 4vw, 1.4rem);
  }
  .badge {
    flex: none;
    background: var(--pink);
    color: var(--black);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
  }
  .meta {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    color: var(--white);
    opacity: 0.85;
    font-size: 0.95rem;
  }
  .venue {
    opacity: 0.75;
  }
</style>
