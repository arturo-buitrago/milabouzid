---
// Bio section. Markdown body is passed in via the `body` slot (rendered in the page from
// the `bio` collection). Photo + presskit download from content; Booking button → #booking.
import Button from './Button.astro';
import Flower from './Flower.astro';
import { isFilled } from '../lib/content';

interface Props {
  heading: string;
  photo?: string;
  presskitPdf?: string;
}
const { heading, photo, presskitPdf } = Astro.props;
const hasPhoto = isFilled(photo);
---

<section id="bio" class="bio">
  <div class="bio-inner">
    <div class="portrait">
      {hasPhoto ? <img src={photo} alt="Mila Bouzid" loading="lazy" /> : <div class="portrait-ph" aria-hidden="true" />}
    </div>

    <div class="body">
      <h2 class="heading">
        <Flower size="0.8em" color="var(--white)" />
        {heading}
      </h2>
      <div class="prose"><slot name="body" /></div>

      <div class="actions">
        <Button href={presskitPdf} variant="solid" disabled={!isFilled(presskitPdf)} download>
          Download artist profile &amp; presskit
        </Button>
        <Button href="#booking" variant="outline">Booking</Button>
      </div>
    </div>
  </div>
</section>

<style>
  .bio {
    position: relative;
    padding: 3rem 1.25rem;
    /* red velvet full-bleed with a warm flare (mockup) */
    background-color: #2a0a10;
    background-image:
      radial-gradient(50% 40% at 22% 45%, rgba(255, 210, 150, 0.28), rgba(255, 160, 110, 0) 60%),
      radial-gradient(130% 110% at 30% 20%, #4d1018 0%, #340a12 45%, #1c060a 100%);
  }
  .bio-inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }
  .portrait {
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }
  .portrait img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .portrait-ph {
    aspect-ratio: 4 / 5;
    /* warm-toned placeholder to match the velvet portrait */
    background:
      radial-gradient(60% 50% at 50% 40%, rgba(255, 220, 160, 0.35), transparent 60%),
      linear-gradient(150deg, #7a2a20, #2a0a10);
  }
  .heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1rem;
    font-family: var(--font-display);
    color: var(--yellow);
    font-size: clamp(1.6rem, 6vw, 2.4rem);
  }
  .prose {
    color: var(--white);
    opacity: 0.9;
    line-height: 1.65;
  }
  .prose :global(p) {
    margin: 0 0 1rem;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 768px) {
    .bio {
      padding: 5rem 1.25rem;
    }
    .bio-inner {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      align-items: center;
      gap: 2.5rem;
    }
  }
</style>
