---
// Sticky nav. Labels are site structure (not editable content), so they live here.
// Mobile: a toggle button reveals the menu. Desktop: links are always inline.
// (Uses a small script for the mobile toggle — a plain <details> can't stay open on desktop.)
const links = [
  { href: '#home', label: 'Home' },
  { href: '#listen', label: 'Listen' },
  { href: '#events', label: 'Live events' },
  { href: '#booking', label: 'Booking' },
  { href: '#bio', label: 'Bio' },
];
---

<nav class="nav" aria-label="Primary">
  <button
    class="hamburger"
    type="button"
    aria-expanded="false"
    aria-controls="nav-menu"
    aria-label="Toggle menu"
    data-nav-toggle
  >
    <svg class="i-open" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
      <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M3 6h18M3 12h18M3 18h18" />
    </svg>
    <svg class="i-close" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
      <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M5 5l14 14M19 5L5 19" />
    </svg>
  </button>

  <ul id="nav-menu" class="links">
    {links.map((l) => (
      <li><a href={l.href}>{l.label}</a></li>
    ))}
  </ul>
</nav>

<script>
  const nav = document.querySelector('.nav');
  const toggle = nav?.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const setOpen = (open: boolean) => {
    nav?.classList.toggle('is-open', open);
    toggle?.setAttribute('aria-expanded', String(open));
  };
  toggle?.addEventListener('click', () => setOpen(nav?.classList.contains('is-open') !== true));
  nav?.querySelectorAll('.links a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 0.75rem 1rem;
  }

  .hamburger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 999px;
    color: var(--white);
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    cursor: pointer;
  }
  .hamburger .i-close {
    display: none;
  }
  .nav.is-open .hamburger .i-open {
    display: none;
  }
  .nav.is-open .hamburger .i-close {
    display: block;
  }

  /* Mobile menu: hidden until open. */
  .links {
    position: absolute;
    right: 1rem;
    top: calc(100% - 0.2rem);
    list-style: none;
    margin: 0;
    padding: 0.5rem;
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 190px;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
    border-radius: 14px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
  }
  .nav.is-open .links {
    display: flex;
  }
  .links a {
    display: block;
    padding: 0.6rem 0.9rem;
    border-radius: 8px;
    color: var(--white);
    text-decoration: none;
    font-weight: 500;
  }
  .links a:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--yellow-neon);
  }

  /* Desktop: inline links, no hamburger. */
  @media (min-width: 768px) {
    .hamburger {
      display: none;
    }
    .links {
      position: static;
      display: flex;
      flex-direction: row;
      background: rgba(0, 0, 0, 0.55);
      backdrop-filter: blur(6px);
      padding: 0.4rem 0.6rem;
      min-width: 0;
      box-shadow: none;
    }
    .links a {
      padding: 0.4rem 0.8rem;
    }
  }
</style>
