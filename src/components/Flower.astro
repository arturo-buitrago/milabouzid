---
// Reusable flower / asterisk motif (Mila's custom SVG, MAFICzKuxz8.svg).
// Recolorable via `color` (maps to currentColor). Decorative by default.
interface Props {
  size?: string; // any CSS length; defaults scale with the parent font-size
  color?: string; // CSS color; defaults to the neon yellow from the mockup
  class?: string;
  label?: string; // if set, the flower is treated as meaningful (not aria-hidden)
}
const { size = '1em', color = 'var(--yellow-neon)', class: className, label } = Astro.props;
---

<svg
  class:list={['flower', className]}
  viewBox="0 0 535.9 528.8"
  width={size}
  height={size}
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  style={`color:${color}`}
>
  <path
    fill="currentColor"
    d="M535.9481 233.4699L502.9636 131.9543 407.6983 162.9081 466.5756 81.8705 380.2212 19.1303 321.3439 100.1679 321.3439 0 214.6042 0 214.6042 100.1679 155.7269 19.1303 69.3725 81.8705 128.2498 162.9081 32.9844 131.9543 0 233.4699 95.2654 264.4235 0 295.3772 32.9844 396.8927 128.2498 365.9392 69.3725 446.9768 155.7269 509.7169 214.6042 428.6793 214.6042 528.8473 321.3439 528.8473 321.3439 428.6793 380.2212 509.7169 466.5756 446.9768 407.6983 365.9392 502.9636 396.8927 535.9481 295.3772 440.6827 264.4235z"
  ></path>
</svg>

<style>
  .flower {
    display: inline-block;
    flex: none;
    vertical-align: middle;
  }
</style>
