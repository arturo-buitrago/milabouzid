---
// Base layout: loads global tokens + placeholder Google Fonts, and provides <head> boilerplate.
// Real Canva fonts get swapped later — replace the two font families in tokens.css and the
// single Google Fonts <link> below (the {{FONT_DISPLAY}} / {{FONT_BODY}} placeholders).
import '../styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Mila Bouzid', description = 'Singer · Voice Actress · Content Creator' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Placeholder web fonts — {{FONT_DISPLAY}} = Playfair Display, {{FONT_BODY}} = Inter.
         Swap the family names here and in tokens.css when the real Canva fonts are known. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;700;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
