---
// Phase 0 scaffold — a blank, themed page proving tokens + fonts are wired site-wide.
// Real sections (Hero, Listen, Live events, Bio, Booking) arrive in Phase 2, bound to content.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="scaffold">
    <p class="eyebrow">Scaffold · Phase 0</p>
    <h1 class="wordmark">MILA BOUZID</h1>
    <p class="tagline">Singer · Voice Actress · Content Creator</p>

    <!-- Swatches: visual proof the color tokens resolve everywhere. Removed in Phase 2. -->
    <div class="swatches" aria-hidden="true">
      <span style="background: var(--yellow)"></span>
      <span style="background: var(--yellow-neon)"></span>
      <span style="background: var(--yellow-pure)"></span>
      <span style="background: var(--purple)"></span>
      <span style="background: var(--pink)"></span>
      <span style="background: var(--white)"></span>
    </div>
  </main>
</BaseLayout>

<style>
  .scaffold {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--yellow-neon);
  }

  .wordmark {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 10vw, 6rem);
    line-height: 1;
    color: var(--yellow);
    letter-spacing: 0.02em;
  }

  .tagline {
    margin: 0;
    font-size: clamp(0.9rem, 2.5vw, 1.1rem);
    color: var(--white);
    opacity: 0.85;
  }

  .swatches {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .swatches span {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.15);
  }
</style>
