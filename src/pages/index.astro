---
// Single-page site. Every section reads from content collections (Phase 1), never literals.
// This is Phase 2 structure + wiring + mobile-first layout; heavy glow/gradient polish is Phase 3.
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import VideoCarousel from '../components/VideoCarousel.astro';
import EventCard from '../components/EventCard.astro';
import BioSection from '../components/BioSection.astro';
import Booking from '../components/Booking.astro';
import Button from '../components/Button.astro';
import Flower from '../components/Flower.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { isFilled } from '../lib/content';

const settings = (await getEntry('settings', 'settings'))!;
const events = (await getCollection('events')).sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);
const videos = (await getCollection('videos')).sort((a, b) => a.data.order - b.data.order);
const bio = (await getEntry('bio', 'bio'))!;
const { Content: BioContent } = await render(bio);
const booking = (await getEntry('booking', 'booking'))!;

const s = settings.data;
---

<BaseLayout>
  <Nav />

  <Hero tagline={s.tagline} heroImage={s.hero_image} social={s.social} />

  <!-- Listen -->
  <section id="listen" class="section listen">
    <h2 class="section-title">Listen</h2>
    <VideoCarousel videos={videos.map((v) => v.data)} />
    <div class="section-cta">
      <Button href={s.repertoire_pdf} variant="solid" disabled={!isFilled(s.repertoire_pdf)} download>
        Download repertoire list
      </Button>
    </div>
  </section>

  <!-- Live events -->
  <section id="events" class="section events">
    <div class="events-head">
      <h2 class="section-title">
        <Flower size="0.9em" color="var(--yellow)" />
        Upcoming events
      </h2>
      <Button
        href={s.bandsintown_url}
        variant="solid"
        disabled={!isFilled(s.bandsintown_url)}
      >
        Follow on Bandsintown
      </Button>
    </div>
    <div class="events-grid">
      {events.map((e) => (
        <EventCard
          title={e.data.title}
          date={e.data.date}
          venue={e.data.venue}
          location={e.data.location}
          moreInfoUrl={e.data.more_info_url}
          soldOut={e.data.sold_out}
        />
      ))}
    </div>
  </section>

  <!-- Bio -->
  <BioSection photo={bio.data.photo} presskitPdf={s.presskit_pdf}>
    <BioContent slot="body" />
  </BioSection>

  <!-- Booking -->
  <Booking heading={booking.data.heading} blurb={booking.data.blurb} email={booking.data.email} />
</BaseLayout>

<style>
  .section {
    padding: 3rem 1.25rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .section-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    color: var(--yellow);
    font-size: clamp(1.6rem, 6vw, 2.4rem);
    margin: 0 0 1.5rem;
  }
  .section-cta {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
  }

  .events-head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .events-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .section {
      padding: 5rem 1.25rem;
    }
    .events-head {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    .events-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
